# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# development | preprod | production
APP_ENV=development

# When true, only ADMIN_EMAILS may use authenticated areas
ADMIN_ONLY=false

LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

SESSION_DRIVER=cookie

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=faktur

# Encryption (falls back to APP_KEY if empty)
ENCRYPTION_KEY=
ANALYTICS_ENCRYPTION_KEY=

# Resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=noreply@fakturapp.cc
MAIL_FROM_NAME=Faktur

# API prefixes
API_PREFIX=/v1
API_PLATFORM_PREFIX=/v1/core/api
API_PLATFORM_ENABLED=true
# API_PLATFORM_TEAM_ALLOWLIST=
API_PLATFORM_WEBHOOK_WORKER=true

# Per-team API quotas (positive integers, leave commented to use defaults)
# API_CREDITS_PER_MINUTE=3
# API_CREDITS_PER_SESSION=100
# API_CREDITS_SESSION_HOURS=5
# API_CREDITS_PER_WEEK=1000
# API_CREDITS_WEEKLY_DAYS=7

# Cloudflare Turnstile
CAPTCHA_ENABLED=false
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/v1/email/oauth/gmail/callback

# AI
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Admins
ADMIN_EMAILS=

# Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# CORS
# CORS_ORIGIN=http://localhost:3000

# Cloudflare R2 (falls back to local fs if empty)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=