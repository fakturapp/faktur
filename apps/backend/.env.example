# =============================================================================
# Faktur Backend - Environment Variables
# =============================================================================

# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=faktur

# Encryption key for 2FA secrets and recovery codes (optional, falls back to APP_KEY)
ENCRYPTION_KEY=

# Encryption key for analytics data (optional, falls back to ENCRYPTION_KEY then APP_KEY)
ANALYTICS_ENCRYPTION_KEY=

# Email - Resend (https://resend.com)
# Required for email verification, password reset, and security notifications
RESEND_API_KEY=
MAIL_FROM_ADDRESS=noreply@fakturapp.cc
MAIL_FROM_NAME=Faktur

API_PREFIX=/api/v1

# Cloudflare Turnstile (captcha)
CAPTCHA_ENABLED=false
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Frontend URL (used for email verification and password reset links)
FRONTEND_URL=http://localhost:3000

# Google OAuth (Gmail email sending)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/api/v1/email/oauth/gmail/callback

# AI provider (Groq)
GROQ_API_KEY=

# Admin Emails
ADMIN_EMAILS=monmail@tqtfrrr.com;lemaildemonpote@tqtfrrr.com

# WebAuthn / Passkeys
# Dev: localhost / http://localhost:3000
# Prod: use the registrable domain (e.g. fakturapp.cc) and frontend origin (e.g. https://dash.fakturapp.cc)
# If not set, defaults are derived from FRONTEND_URL
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# Cloudflare R2 (S3-compatible object storage for images)
# Without these, uploads fall back to local filesystem (dev mode)
#--------------------------------------------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://cdn.example.com
