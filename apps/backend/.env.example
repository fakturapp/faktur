# =============================================================================
# Faktur Backend - Environment Variables
# =============================================================================

# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# Deployment environment: development | preprod | production
# Set to "preprod" on a staging server that shares the real production database
# so the frontend can show a permanent warning. Independent from NODE_ENV.
APP_ENV=development

# When true, only emails listed in ADMIN_EMAILS may use authenticated areas
# (dashboard + API). Non-admins are logged in but redirected to a notice page.
ADMIN_ONLY=false

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=faktur

# Encryption key for 2FA secrets and recovery codes (optional, falls back to APP_KEY)
ENCRYPTION_KEY=

# Encryption key for analytics data (optional, falls back to ENCRYPTION_KEY then APP_KEY)
ANALYTICS_ENCRYPTION_KEY=

# Email - Resend (https://resend.com)
# Required for email verification, password reset, and security notifications
RESEND_API_KEY=
MAIL_FROM_ADDRESS=noreply@fakturapp.cc
MAIL_FROM_NAME=Faktur

API_PREFIX=/api/v1

# Platform meta endpoints (ping, session, usage) - free, no credit charge
API_PLATFORM_PREFIX=/api/platform

# Platform feature flag (defaults to enabled for everyone)
API_PLATFORM_ENABLED=true

# Platform closed beta allowlist (comma-separated team IDs)
# API_PLATFORM_TEAM_ALLOWLIST=

# Webhook dispatch worker (old API_V2_WEBHOOK_WORKER also accepted)
API_PLATFORM_WEBHOOK_WORKER=true

# -----------------------------------------------------------------------------
# API quotas / credit limits (per team)
# -----------------------------------------------------------------------------
# Override the per-team API quota windows enforced by api_credit_middleware.
# All values are positive integers; if a var is unset or non-numeric the
# hardcoded default (shown below in comments) is used.
#
#   API_CREDITS_PER_MINUTE      - sliding 60s window cap (default: 3)
#   API_CREDITS_PER_SESSION     - cap over a rolling SESSION_HOURS window (default: 100)
#   API_CREDITS_SESSION_HOURS   - rolling session window length in hours (default: 5)
#   API_CREDITS_PER_WEEK        - cap over a rolling WEEKLY_DAYS window (default: 1000)
#   API_CREDITS_WEEKLY_DAYS     - rolling weekly window length in days (default: 7)
#
# Each API call emits these response headers so clients can self-throttle:
#   X-Credits-Session-Limit, X-Credits-Weekly-Limit, X-Credits-Per-Minute-Limit
#   X-Credits-Session-Remaining, X-Credits-Weekly-Remaining, X-Credits-Minute-Remaining
# API_CREDITS_PER_MINUTE=3
# API_CREDITS_PER_SESSION=100
# API_CREDITS_SESSION_HOURS=5
# API_CREDITS_PER_WEEK=1000
# API_CREDITS_WEEKLY_DAYS=7

# Cloudflare Turnstile (captcha)
CAPTCHA_ENABLED=false
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Frontend URL (used for email verification and password reset links)
FRONTEND_URL=http://localhost:3000

# Google OAuth (Gmail email sending)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/api/v1/email/oauth/gmail/callback

# AI provider (Groq)
GEMINI_API_KEY=
OPENROUTER_API_KEY

# Admin Emails
ADMIN_EMAILS=monmail@tqtfrrr.com;lemaildemonpote@tqtfrrr.com

# WebAuthn / Passkeys
# Dev: localhost / http://localhost:3000
# Prod: use the registrable domain (e.g. fakturapp.cc) and frontend origin (e.g. https://dash.fakturapp.cc)
# If not set, defaults are derived from FRONTEND_URL
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# Cloudflare R2 (S3-compatible object storage for images)
# Without these, uploads fall back to local filesystem (dev mode)
#--------------------------------------------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://cdn.example.com