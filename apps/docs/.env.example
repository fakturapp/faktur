# =============================================================================
# Faktur Developer Portal — environment variables
# =============================================================================
# Production values. For local development, copy this file to `.env` and
# replace each value with its localhost equivalent (or pull the committed
# `apps/docs/.env` which already targets localhost).
# =============================================================================


# -----------------------------------------------------------------------------
# Faktur Public API
# -----------------------------------------------------------------------------
# Base URL for business resources (clients, invoices, products, …) injected
# into every code snippet in the docs. Authenticate with a Bearer fk_live_…
# API key from platform.fakturapp.cc.
NEXT_PUBLIC_API_BASE_URL=https://api.fakturapp.cc/api/v1

# Base URL for platform meta endpoints (ping, session, usage) — free, no
# credit charge. Used by the API Explorer prefix toggle.
NEXT_PUBLIC_API_PLATFORM_BASE_URL=https://api.fakturapp.cc/api/platform


# -----------------------------------------------------------------------------
# Sibling apps (header / footer links + OpenGraph metadataBase)
# -----------------------------------------------------------------------------
# Public URL of THIS portal — used by Next.js metadataBase for OG images.
NEXT_PUBLIC_DOCS_URL=https://developers.fakturapp.cc

# Main Faktur web app — "App principale" footer link.
NEXT_PUBLIC_DASHBOARD_URL=https://fakturapp.cc

# Faktur Developer Platform — referenced from the quickstart "Generate an
# API key" step (links into /api-keys on the platform).
NEXT_PUBLIC_PLATFORM_URL=https://platform.fakturapp.cc
