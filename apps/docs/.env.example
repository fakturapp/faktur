# Faktur Developer Portal — environment variables

# Public API V2 base URL — used in all code snippets and reference pages
# Local: http://localhost:3333/api/v2
# Prod:  https://api.fakturapp.cc/api/v2  (or https://api.fakturapp.cc/v2)
NEXT_PUBLIC_API_V2_BASE_URL=https://api.fakturapp.cc/api/v2

# Main Faktur app URL — used by links pointing to the dashboard
# Local: http://localhost:3000
# Prod:  https://fakturapp.cc
NEXT_PUBLIC_DASHBOARD_URL=https://fakturapp.cc
