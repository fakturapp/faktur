NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3333/api/v1

# Deployment environment: development | preprod | production
# "preprod" shows a permanent warning banner on every page.
NEXT_PUBLIC_APP_ENV=development

# When "true", non-admin users are redirected to a restricted-access notice.
# Must match the backend ADMIN_ONLY value.
NEXT_PUBLIC_ADMIN_ONLY=false

# Cloudflare Turnstile (captcha)
NEXT_PUBLIC_CAPTCHA_ENABLED=false
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=

# Developer portal URL — used by the "Documentation" button on /dashboard/settings/api-keys
NEXT_PUBLIC_DOCS_URL=https://developers.fakturapp.cc

# Public API V2 base URL — shown in code snippets (revealed-key dialog, etc.)
NEXT_PUBLIC_API_V2_BASE_URL=https://api.fakturapp.cc/v2
